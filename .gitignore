# ── STM32CubeIDE build output folders (fully auto-generated) ─────────────────
# Covers: makefile, subdir.mk, objects.mk, sources.mk, objects.list,
#         *.o, *.d, *.su, *.cyclo, *.elf, *.bin, *.map, *.list, build.bat
Debug/
Release/

# ── IDE / Eclipse settings (machine-specific paths) ──────────────────────────
# .cproject / .project / .mxproject / SENTToUSB.ioc are tracked (needed for import)
.settings/
*.launch

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Large binary datasheets (optional — remove these lines to track PDFs) ────
*.pdf
